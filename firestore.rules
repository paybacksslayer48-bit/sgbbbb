rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write since the operations are proxied exclusively through our secure Express API endpoints
    match /products/{productId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /telegramDrafts/{draftId} {
      allow read, write: if true;
    }
    match /config/telegramConfig {
      allow read, write: if true;
    }
    match /config/visitorCounter {
      allow read, write: if true;
    }
    match /visitors/{visitorId} {
      allow read, write: if true;
    }
    // Safety fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
